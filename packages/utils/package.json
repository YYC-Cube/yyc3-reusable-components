{
  "name": "@yyc3/utils",
  "version": "1.0.0",
  "description": "YYC³工具函数库 - 通用工具函数",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "require": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsup": "^8.0.0",
    "jest": "^29.7.0",
    "@testing-library/jest-dom": "^6.1.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YYC-Cube/yyc3-reusable-components.git",
    "directory": "packages/utils"
  },
  "keywords": [
    "yyc3",
    "utils",
    "tools",
    "functions"
  ],
  "author": "YYC³ Team <admin@0379.email>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/YYC-Cube/yyc3-reusable-components/issues"
  },
  "homepage": "https://github.com/YYC-Cube/yyc3-reusable-components#readme",
  "types": "./dist/index.d.ts"
}
