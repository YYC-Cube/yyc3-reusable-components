{
  "name": "@yyc3/core",
  "version": "1.0.0",
  "description": "YYC³核心库 - 国际化、性能监控等核心功能",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "require": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsup": "^8.0.0",
    "eslint": "^10.1.0",
    "prettier": "^3.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YYC-Cube/yyc3-reusable-components.git",
    "directory": "packages/core"
  },
  "keywords": [
    "yyc3",
    "core",
    "i18n",
    "monitoring",
    "performance"
  ],
  "author": "YYC³ Team <admin@0379.email>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/YYC-Cube/yyc3-reusable-components/issues"
  },
  "homepage": "https://github.com/YYC-Cube/yyc3-reusable-components#readme",
  "types": "./dist/index.d.ts"
}
