    "react-resizable-panels": "^2.1.7",
    "react-hook-form": "^7.55.0",
    "sonner": "^2.0.3",
    "vaul": "^1.1.2",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.3.0",
    "tsup": "^8.0.0",
    "vite": "^5.0.0",
    "jest": "^29.7.0",
    "@testing-library/react": "^14.1.0",
