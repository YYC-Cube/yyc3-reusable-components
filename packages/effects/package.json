{
  "name": "@yyc3/effects",
  "version": "1.0.0",
  "description": "YYC³特效组件库 - 3D和动画特效",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "require": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@yyc3/ui": "workspace:*",
    "framer-motion": "^10.16.0",
    "three": "^0.158.0",
    "@react-three/fiber": "^8.15.0",
    "@react-three/drei": "^9.88.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.2",
    "tsup": "^8.0.0",
    "vite": "^8.0.3",
    "jest": "^29.7.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/jest-dom": "^6.1.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YYC-Cube/yyc3-reusable-components.git",
    "directory": "packages/effects"
  },
  "keywords": [
    "yyc3",
    "effects",
    "3d",
    "animation",
    "components",
    "react"
  ],
  "author": "YYC³ Team <admin@0379.email>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/YYC-Cube/yyc3-reusable-components/issues"
  },
  "homepage": "https://github.com/YYC-Cube/yyc3-reusable-components#readme",
  "types": "./dist/index.d.ts"
}
