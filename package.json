{
  "name": "yyc3-reusable-components",
  "version": "1.0.0",
  "private": true,
  "description": "YYC³ Component Library - Enterprise-grade React Component Library with 200+ Components",
  "author": "YYC³ Team <admin@0379.email>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YYC-Cube/yyc3-reusable-components.git"
  },
  "bugs": {
    "url": "https://github.com/YYC-Cube/yyc3-reusable-components/issues"
  },
  "homepage": "https://github.com/YYC-Cube/yyc3-reusable-components#readme",
  "keywords": [
    "yyc3",
    "yanyucloudcube",
    "component-library",
    "ui-components",
    "business-components",
    "ai-components",
    "smart-components",
    "react-components",
    "monorepo",
    "react",
    "typescript",
    "tailwindcss",
    "radix-ui",
    "cyberpunk",
    "enterprise"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:ui": "turbo run test:ui",
    "test:coverage": "turbo run test:coverage",
    "test:run": "turbo run test:run",
    "test:watch": "turbo run test:watch",
    "test:changed": "turbo run test:changed",
    "test:performance": "vitest --config vitest.performance.config.ts run",
    "test:performance:regression": "node scripts/check-performance-regression.js",
    "test:performance:report": "node scripts/generate-performance-report.js",
    "test:performance:compare": "node scripts/compare-performance-baseline.js",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=... && changeset publish",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "deploy-storybook": "storybook-to-ghpages"
  },
  "devDependencies": {
    "@changesets/cli": "^2.26.2",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^1.0.4",
    "@vitest/ui": "^1.0.4",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^23.0.1",
    "prettier": "^3.1.0",
    "turbo": "^2.8.21",
    "typescript": "^5.3.0",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.10.0",
  "workspaces": [
    "packages/*"
  ]
}
